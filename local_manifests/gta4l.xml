<?xml version="1.0" encoding="UTF-8"?>
<manifest>

  <!-- ============================================================
       Ubuntu Touch - Halium 12.0 - Samsung Galaxy Tab A7 LTE
       Device  : SM-T505 / SM-T505N / SM-T505C / SM-T507
       Codename: gta4l
       SoC     : Qualcomm SM6115 (Bengal)
       Base    : LineageOS 19.1 (Android 12)
       ============================================================ -->

  <!-- LineageOS remotes -->
  <remote name="lineageos"
          fetch="https://github.com/LineageOS"
          revision="lineage-19.1" />

  <remote name="themuppets"
          fetch="https://github.com/TheMuppets"
          revision="lineage-19.1" />

  <!-- Device tree (LTE variant) -->
  <project name="android_device_samsung_gta4l"
           path="device/samsung/gta4l"
           remote="lineageos"
           revision="lineage-19.1" />

  <!-- Common device tree (shared with gta4lwifi) -->
  <project name="android_device_samsung_gta4l-common"
           path="device/samsung/gta4l-common"
           remote="lineageos"
           revision="lineage-19.1" />

  <!-- Kernel - SM6115 (Bengal) -->
  <project name="android_kernel_samsung_sm6115"
           path="kernel/samsung/sm6115"
           remote="lineageos"
           revision="lineage-19.1" />

  <!-- Vendor blobs -->
  <project name="proprietary_vendor_samsung_gta4l"
           path="vendor/samsung/gta4l"
           remote="themuppets"
           revision="lineage-19.1" />

  <project name="proprietary_vendor_samsung_gta4l-common"
           path="vendor/samsung/gta4l-common"
           remote="themuppets"
           revision="lineage-19.1" />

</manifest>
